    "type-check": "vue-tsc --build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vue-tsc": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
