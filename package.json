{
  "name": "@viyuni/monorepo",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "YanChenBai",
  "workspaces": [
    "services/*",
    "packages/*",
    "apps/*",
    "apps/games/*",
    "apps/tools/*",
    "scripts",
    "docs/*",
    "tools/*",
    "!.context/*"
  ],
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev:web": "bun --filter @viyuni/scripts dev",
    "dev:bevent-relay": "bun --filter @viyuni/bevent-relay dev",
    "dev:control-panel": "bun --filter @viyuni/control-panel dev",
    "build:web": "bun --filter @viyuni/scripts build",
    "type-check": "vue-tsc --build"
  },
  "devDependencies": {
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "~5.9.3",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*": "bun run fmt && bun run lint:fix"
  }
}
